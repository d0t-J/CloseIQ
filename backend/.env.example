# ---------- Core AI provider (recommended: OpenRouter) ----------
# Get from: https://openrouter.ai/
OPENROUTER_API_KEY=

# Backward-compatible fallback (optional if OPENROUTER_API_KEY is set)
OPENAI_API_KEY=

# Defaults are already set in code; only override if needed
OPENAI_API_BASE=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ---------- App ----------
SECRET_KEY=change-me
EMBEDDINGS_PROVIDER=openai
CHROMADB_PATH=./chromadb_data

# ---------- Supabase (optional for backend today, keep for future features) ----------
# Project URL and service role key from Supabase dashboard
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

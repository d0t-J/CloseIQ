# ---------- Frontend -> Backend ----------
# Dev backend URL
REACT_APP_BACKEND_URL=http://localhost:8000

# ---------- Deepgram (required for live transcription) ----------
# Get from: https://deepgram.com/
REACT_APP_DEEPGRAM_API_KEY=

# ---------- Supabase (required for login flow in current app) ----------
# Get values from Supabase project settings -> API
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
